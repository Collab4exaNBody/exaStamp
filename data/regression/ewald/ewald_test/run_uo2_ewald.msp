configuration:
  physics:
    units:
      length: angstrom
      mass: Dalton
      time: picosecond
      charge: elementary_charge
      temperature: kelvin
      amount: particle
      luminosity: candela
      angle: radian
      energy: joule
  logging:
    debug: false
  profiling:
    summary: false

grid_flavor: grid_flavor_full
  
global:
  simulation_end_iteration: 1000
  simulation_log_frequency: 10
  simulation_dump_thermo_frequency: 1
  simulation_dump_frequency: -1
  rcut_inc: 1.0 ang
  dt: 0.001 ps
  force_flush_file: true
  file: "thermo_exastamp_ewald.csv"

species:
  - O: { mass: 15.999000 Da , z: 8 , charge: -1.1104 e- }
  - U: { mass: 238.02891 Da , z: 92 , charge: 2.2208 e- }
    
compute_force_singlepass:
  - eam_alloy_force: { rcut: 10.0 ang , parameters: { file: UO_test.eam.alloy } , eam_rho: true , eam_rho2emb: true , eam_ghost: true , eam_force: true , eam_symmetry: false }
  
compute_force:
  - compute_force_singlepass
  - ewald_short_range_pc
#  - ewald_long_range

input_data:
  - domain:
      cell_size: 5.5 ang
      periodic: [true,true,true]
      expandable: false
  - read_xyz_file_with_xform:
      file: "UO2_disturbed.xyz"
      pbc_adjust_xform: true
  - ewald_config:
      epsilon: 1.0e-05
      alpha: 0.0
      radius: 24.0 ang
      kmax: 8
  
dump_data:
  - timestep_file: "exastamp/output_%09d.xyz"
  - write_xyz:
      fields: [ id , type, force]

+first_iteration:
  - dump_data
