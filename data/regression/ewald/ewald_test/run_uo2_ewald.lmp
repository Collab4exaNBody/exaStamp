units        metal
dimension   3
boundary    p p p
atom_style  charge

read_data    UO2_disturbed_charge.lmp

group  U type 1
set group U charge 2.2208

group  O type 2
set group O charge -1.1104
    
pair_style hybrid/overlay eam/alloy coul/long 10.0
pair_coeff * * coul/long
pair_coeff * * eam/alloy UO_test.eam.alloy U O

kspace_style ewald 1.0e-5
  
thermo       10
thermo_style custom step time atoms etotal ke pe temp 

variable  peat equal pe/atoms
variable  keat equal ke/atoms
variable  etotalat equal etotal/atoms
variable  T equal temp
variable  nats equal atoms
variable  s equal step
variable  t equal time
        
fix 2 all print 1 "${s} ${t} ${nats} ${etotalat} ${keat} ${peat} ${T}" file thermo_lammps_ewald.csv screen no

neighbor     1.0 bin
neigh_modify delay 0 every 1 check yes

fix          1 all nve
dump         d_1 all custom 1 lammps/dump.*.dump id type x y z fx fy fz
run          100
