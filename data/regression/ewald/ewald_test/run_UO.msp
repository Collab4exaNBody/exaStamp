compute_force_singlepass:
  - eam_alloy_force: { rcut: 11.0 ang , parameters: { file: UO_test.eam.alloy } , eam_rho: true , eam_rho2emb: true , eam_ghost: true , eam_force: true , eam_symmetry: false }
  
compute_force:
  - ewald_short_range_pc:
      ewald_config:
        epsilon: 1.0e-5
        alpha: 0.0
        radius: 11. ang
        kmax: 8
        size: [100. ang, 100. ang, 100. ang]
  - ewald_long_range
  - compute_force_singlepass

species:
  - O: { mass: 15.999 Da , z: 8 , charge: -1.1104 e- }
  - U: { mass: 238.029 Da , z: 92 , charge: 2.2208 e- }

grid_flavor: grid_flavor_full

input_data:
  - read_xyz_file_with_xform:
      file: "EDGE_dislo_2200_K.124000.xyz"
      pbc_adjust_xform: true
  - ewald_init
  - sum_charges
#  - ewald_potential_energy_shift

ewald_init:
  epsilon: 1.0E-05
  alpha: 0.0
  radius: 11.0 ang
  kmax: 8
  
domain:
  cell_size: 20. ang
  periodic: [true,true,true]
  expandable: false
  
final_dump_data: nop

global:
  simulation_end_iteration: 2
  simulation_log_frequency: 1
  rcut_inc: 1.0 ang
  dt: 1.0e-3 ps
  simulation_dump_frequency: -1
  simulation_dump_thermo_frequency: 1
  analysis_dump_frequency: -1


