includes:
  - baseline.yaml
  - config_nose_hoover.msp

numerical_scheme: verlet_nhnpt

init_nose_hoover:
  algo: NPT
  Tstart: 150. K
  Tend:   150. K
  Tdamp:  0.05 ps
  tchain: 3
  Pxxstart: 1.0e9
  Pxxend:   1.0e9
  Pxxdamp:  0.5 ps
  Pyystart: 1.0e9
  Pyyend:   1.0e9
  Pyydamp:  0.5 ps
  Pzzstart: 1.0e9
  Pzzend:   1.0e9
  Pzzdamp:  0.5 ps
  pchain: 3
  Pcouple:  XYZ
