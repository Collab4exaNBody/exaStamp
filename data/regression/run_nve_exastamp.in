init_parameters:
  rebind: { parameters: eam_alloy_parameters }
  body:
    - eam_alloy_init:
        parameters:
          file: "Ta.eam.alloy"

chunk_neighbors:
  config:
    chunk_size: 1
    build_particle_offset: true

compute_force:
  rebind: { parameters: eam_alloy_parameters }
  body:
#    - eam_alloy_force: { rcut: 5.30 ang , eam_rho: true , eam_rho2emb: true, eam_ghost: true , eam_force: true , eam_symmetry: false }
    - eam_alloy_force: { rcut: 5.30 ang }

grid_flavor: grid_flavor_multimat
  
global:
  max_iteration: 100
  simulation_thermostate_screen_frequency: 50
  simulation_thermostate_file_frequency: 1
  simulation_snapshot_frequency: -1
  rcut_inc: 2.0 ang
  dt: 0.001 ps

species:
  - Ta: { mass: 180.95 Da, z: 73, charge: 0 e- }

setup_system:
  - domain:
      cell_size: 6.6 ang
      periodic: [true, true, true]
      expandable: false
  - read_xyz_file_with_xform:
      filename: "Ta_disturbed.xyz"

final_dump: nop
