includes:
  - baseline_single_specy.yaml

configuration:
  debug:
    graph: true
    graph_lod: 1    # 2 to show unconnected nodes
    graph_fmt: dot
    graph_filter: [ '.*\.do_init_temperature' , '.*\.end_iteration' ]

yukawa_compute_force:
  rcut: 10.0 ang
  parameters: { A: 2.43 eV*ang , kappa: 4.1 1./ang }

compute_force: yukawa_compute_force
