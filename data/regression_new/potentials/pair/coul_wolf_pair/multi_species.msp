includes:
  - baseline_multi_species.yaml

coul_wolf_pair_multi_force:
  rcut: 8. ang
  common_parameters: { alpha: 0.2 ang^-1 , rc: 7.0 ang }
  parameters:
    - { type_a: Zn , type_b: Zn , rcut: 8.0 ang , parameters: { alpha: 0.2 ang^-1, rc: 7.0 ang } }
    - { type_a: Cu , type_b: Zn , rcut: 8.0 ang , parameters: { alpha: 0.3 ang^-1, rc: 7.0 ang } }

compute_force: coul_wolf_pair_multi_force
