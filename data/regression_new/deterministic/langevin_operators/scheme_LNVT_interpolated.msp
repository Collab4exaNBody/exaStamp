includes:
  - baseline.yaml

numerical_scheme: verlet_lnvt
langevin_thermostat:
  {
    tserie: [ 0, 0.5, 1.2, 2.0 ],
    Tserie: [ 5, 300, 100, 400 ],
    gamma: 0.1 ps^-1,
  }

simulation_epilog:
  - check_values:
      file: check_verlet_lnvt_interpolated.dat
      samples: 1000
      pos_threshold: 1e-10
      acc_threshold: 1e-10
      vel_threshold: 1e-10
