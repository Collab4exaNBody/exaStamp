includes:
  - baseline.yaml

numerical_scheme: verlet_lnvt
langevin_thermostat: { Tstart: 20. K, Tstop: 20. K, gamma: 0.1 ps^-1 }

simulation_epilog:
  - check_values:
      file: check_verlet_lnvt_constant.dat
      samples: 1000
      pos_threshold: 1e-10
      acc_threshold: 1e-10
      vel_threshold: 1e-10
